# Backend bmx — configuration

# Base de données. Postgres en prod, SQLite par défaut en local.
# DATABASE_URL=postgres://user:pass@localhost:5432/bmx
DATABASE_URL=sqlite://bmx.db?mode=rwc

# Secret de signature des JWT (À CHANGER en prod).
JWT_SECRET=dev-secret-change-me
JWT_TTL_HOURS=72

# Adresse d'écoute HTTP.
BIND_ADDR=0.0.0.0:8080

# Niveau de logs (tracing-subscriber).
RUST_LOG=info,api=debug,sqlx=warn

# Imports externes (cron intégré).
IMPORT_ENABLED=true
IMPORT_INTERVAL_HOURS=6
IMPORT_ON_BOOT=true
# Flux YouTube source des vidéos (défaut : chaîne Thrasher).
# THRASHER_YT_FEED=https://www.youtube.com/feeds/videos.xml?user=ThrasherMagazine

# Paiement Stripe (abonnement premium « bmx+ »).
# Laisser vide en dev : les routes /billing renvoient « paiement non configuré ».
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_PRICE_ID=price_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# URL du front pour les redirections Checkout/Portal.
APP_BASE_URL=http://localhost:3000

# Webhook RevenueCat (achat in-app de l'app mobile) : jeton Bearer attendu.
# REVENUECAT_WEBHOOK_AUTH=un-secret-partagé
